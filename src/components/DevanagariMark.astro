---
interface Props {
  size?: number;
  opacity?: number;
  color?: string;
  class?: string;
}
const {
  size = 240,
  opacity = 0.08,
  color = '#C99A4B',
  class: cls = '',
} = Astro.props;
---

<span
  aria-hidden="true"
  class:list={['font-devanagari pointer-events-none select-none leading-none', cls]}
  style={`font-size:${size}px; opacity:${opacity}; color:${color}; line-height:1;`}
>
  श्री
</span>
