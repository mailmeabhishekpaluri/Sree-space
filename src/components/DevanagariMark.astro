---
interface Props {
  size?: number;
  opacity?: number;
  /** Kept for API compatibility — image carries its own gold colour */
  color?: string;
  class?: string;
}
const {
  size = 240,
  opacity = 0.08,
  class: cls = '',
} = Astro.props;
---

<img
  src="/images/branding/sree-mark.png"
  alt=""
  aria-hidden="true"
  class:list={['pointer-events-none select-none', cls]}
  style={`height:${size}px; width:auto; opacity:${opacity}; display:block;`}
  loading="lazy"
  decoding="async"
/>
