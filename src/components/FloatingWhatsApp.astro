---
import { WHATSAPP_OPTIONS, WHATSAPP_NUMBER } from '../data/contact';
---

<!-- Floating trigger button -->
<button
  id="wa-trigger"
  aria-label="Chat with Likhitha on WhatsApp"
  aria-expanded="false"
  aria-controls="wa-panel"
  class="wa-trigger"
>
  <!-- WhatsApp SVG -->
  <svg width="28" height="28" viewBox="0 0 24 24" fill="white" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</button>

<!-- Panel / modal -->
<div
  id="wa-panel"
  role="dialog"
  aria-modal="true"
  aria-label="Contact Likhitha on WhatsApp"
  aria-hidden="true"
  class="wa-panel"
>
  <div class="wa-panel-inner">
    <!-- Header -->
    <div class="wa-panel-header">
      <h2 class="wa-heading">Hi! How can Likhitha help?</h2>
      <button
        id="wa-close"
        aria-label="Close"
        class="wa-close"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="4" x2="14" y2="14"/>
          <line x1="14" y1="4" x2="4" y2="14"/>
        </svg>
      </button>
    </div>

    <!-- Form -->
    <form id="wa-form" novalidate>
      <!-- Name input -->
      <div class="wa-field">
        <label for="wa-name" class="wa-label">Your name</label>
        <input
          id="wa-name"
          name="name"
          type="text"
          required
          autocomplete="given-name"
          placeholder="Your name"
          class="wa-input"
          aria-required="true"
        />
        <p id="wa-name-error" class="wa-error" aria-live="polite" hidden>Please enter your name.</p>
      </div>

      <!-- Topic chips -->
      <div class="wa-field">
        <p class="wa-label" id="wa-chips-label">What are you curious about? <span class="wa-required">(pick one or more)</span></p>
        <div class="wa-chips" role="group" aria-labelledby="wa-chips-label" aria-required="true">
          {WHATSAPP_OPTIONS.map((opt) => (
            <button
              type="button"
              class="wa-chip"
              data-option={opt}
              aria-pressed="false"
            >
              {opt}
            </button>
          ))}
        </div>
        <p id="wa-chips-error" class="wa-error" aria-live="polite" hidden>Please select at least one topic.</p>
      </div>

      <!-- Submit -->
      <button type="submit" class="wa-submit">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0;">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Send on WhatsApp
      </button>
    </form>
  </div>
</div>

<!-- Backdrop (mobile) -->
<div id="wa-backdrop" class="wa-backdrop" aria-hidden="true"></div>

<style>
  /* ── Trigger button ───────────────────────────── */
  .wa-trigger {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 50;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25D366;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,0.18), 0 1px 4px rgba(0,0,0,0.10);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .wa-trigger:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 24px rgba(0,0,0,0.22), 0 2px 6px rgba(0,0,0,0.12);
  }
  .wa-trigger:focus-visible {
    outline: 2px solid #C99A4B;
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-trigger { transition: none; }
  }

  /* ── Panel ────────────────────────────────────── */
  .wa-panel {
    position: fixed;
    z-index: 49;
    /* Desktop: anchored above button */
    bottom: calc(1.5rem + 56px + 12px);
    right: 1.5rem;
    width: 340px;
    max-height: calc(100vh - 10rem);
    overflow-y: auto;
    background: #FBF8F1;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(31,42,36,0.16), 0 2px 8px rgba(31,42,36,0.08);
    /* hidden state */
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  .wa-panel[aria-hidden="false"] {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-panel { transition: none; }
  }

  /* Mobile: centered modal */
  @media (max-width: 639px) {
    .wa-panel {
      bottom: auto;
      right: auto;
      top: 50%;
      left: 50%;
      transform: translate(-50%, calc(-50% + 8px));
      width: calc(100vw - 2rem);
      max-width: 360px;
      max-height: 90vh;
    }
    .wa-panel[aria-hidden="false"] {
      transform: translate(-50%, -50%);
    }
  }

  /* ── Backdrop (mobile only) ───────────────────── */
  .wa-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 48;
    background: rgba(31,42,36,0.45);
    opacity: 0;
    transition: opacity 0.22s ease;
  }
  .wa-backdrop.is-open {
    opacity: 1;
  }
  @media (max-width: 639px) {
    .wa-backdrop { display: block; pointer-events: none; }
    .wa-backdrop.is-open { pointer-events: auto; }
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-backdrop { transition: none; }
  }

  /* ── Panel inner ──────────────────────────────── */
  .wa-panel-inner {
    padding: 1.5rem;
  }
  .wa-panel-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .wa-heading {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.45rem;
    font-weight: 500;
    line-height: 1.2;
    color: #2C5F3F;
    margin: 0;
  }
  .wa-close {
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: #5C6B62;
    padding: 4px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease;
    margin-top: 2px;
  }
  .wa-close:hover { color: #2C5F3F; }
  .wa-close:focus-visible { outline: 2px solid #C99A4B; outline-offset: 2px; }

  /* ── Form fields ──────────────────────────────── */
  .wa-field {
    margin-bottom: 1.1rem;
  }
  .wa-label {
    display: block;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: #2C5F3F;
    margin-bottom: 0.5rem;
    letter-spacing: 0.01em;
  }
  .wa-required {
    font-weight: 400;
    color: #5C6B62;
  }
  .wa-input {
    width: 100%;
    padding: 0.6rem 0.85rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.95rem;
    color: #1F2A24;
    background: white;
    border: 1.5px solid #C5D3C0;
    border-radius: 8px;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.15s ease;
  }
  .wa-input:focus {
    border-color: #2C5F3F;
  }
  .wa-input.is-invalid {
    border-color: #c0392b;
  }
  .wa-error {
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.78rem;
    color: #c0392b;
    margin-top: 0.3rem;
    margin-bottom: 0;
  }

  /* ── Chips ────────────────────────────────────── */
  .wa-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .wa-chip {
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1.5px solid #C5D3C0;
    background: transparent;
    color: #2C5F3F;
    cursor: pointer;
    transition: background 0.14s ease, border-color 0.14s ease, color 0.14s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .wa-chip:hover {
    border-color: #C99A4B;
    background: rgba(201,154,75,0.07);
  }
  .wa-chip[aria-pressed="true"] {
    background: rgba(201,154,75,0.14);
    border-color: #C99A4B;
    color: #A37A30;
  }
  .wa-chip:focus-visible {
    outline: 2px solid #C99A4B;
    outline-offset: 2px;
  }
  .wa-chips.is-invalid .wa-chip {
    border-color: #e0a8a0;
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-chip { transition: none; }
  }

  /* ── Submit button ────────────────────────────── */
  .wa-submit {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    margin-top: 0.25rem;
    font-family: Inter, system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: white;
    background: #25D366;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .wa-submit:hover { background: #1fba59; }
  .wa-submit:focus-visible { outline: 2px solid #C99A4B; outline-offset: 2px; }
  @media (prefers-reduced-motion: reduce) {
    .wa-submit { transition: none; }
  }
</style>

<script define:vars={{ WHATSAPP_NUMBER, WHATSAPP_OPTIONS }}>
  const trigger   = document.getElementById('wa-trigger');
  const panel     = document.getElementById('wa-panel');
  const closeBtn  = document.getElementById('wa-close');
  const backdrop  = document.getElementById('wa-backdrop');
  const form      = document.getElementById('wa-form');
  const nameInput = document.getElementById('wa-name');
  const nameError = document.getElementById('wa-name-error');
  const chipsWrap = document.querySelector('.wa-chips');
  const chipsError= document.getElementById('wa-chips-error');
  const chips     = document.querySelectorAll('.wa-chip');

  // ── Focus trap ──────────────────────────────────
  function getFocusable() {
    return Array.from(panel.querySelectorAll(
      'button, input, [tabindex]:not([tabindex="-1"])'
    )).filter(el => !el.disabled);
  }

  function trapFocus(e) {
    const focusable = getFocusable();
    const first = focusable[0];
    const last  = focusable[focusable.length - 1];
    if (e.key === 'Tab') {
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault(); last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault(); first.focus();
      }
    }
    if (e.key === 'Escape') closePanel();
  }

  // ── Open / close ────────────────────────────────
  function openPanel(option) {
    panel.setAttribute('aria-hidden', 'false');
    trigger.setAttribute('aria-expanded', 'true');
    backdrop.classList.add('is-open');
    document.addEventListener('keydown', trapFocus);

    if (option) {
      const target = Array.from(chips).find(c => c.dataset.option === option);
      if (target) target.setAttribute('aria-pressed', 'true');
    }

    setTimeout(() => {
      if (!nameInput.value.trim()) {
        nameInput.focus();
      } else {
        form.querySelector('.wa-submit')?.focus();
      }
    }, 50);
  }

  function closePanel() {
    panel.setAttribute('aria-hidden', 'true');
    trigger.setAttribute('aria-expanded', 'false');
    backdrop.classList.remove('is-open');
    document.removeEventListener('keydown', trapFocus);
    trigger.focus();
  }

  trigger.addEventListener('click', () => {
    const isOpen = panel.getAttribute('aria-hidden') === 'false';
    isOpen ? closePanel() : openPanel();
  });
  closeBtn.addEventListener('click', closePanel);
  backdrop.addEventListener('click', closePanel);

  // ── Chips toggle ────────────────────────────────
  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const pressed = chip.getAttribute('aria-pressed') === 'true';
      chip.setAttribute('aria-pressed', String(!pressed));
      // Clear chip error on first selection
      const anySelected = Array.from(chips).some(c => c.getAttribute('aria-pressed') === 'true');
      if (anySelected) {
        chipsWrap.classList.remove('is-invalid');
        chipsError.hidden = true;
      }
    });
  });

  // ── Form submit ──────────────────────────────────
  form.addEventListener('submit', (e) => {
    e.preventDefault();

    let valid = true;

    // Validate name
    const name = nameInput.value.trim();
    if (!name) {
      nameInput.classList.add('is-invalid');
      nameError.hidden = false;
      valid = false;
    } else {
      nameInput.classList.remove('is-invalid');
      nameError.hidden = true;
    }

    // Validate chips
    const selected = Array.from(chips)
      .filter(c => c.getAttribute('aria-pressed') === 'true')
      .map(c => c.dataset.option);

    if (selected.length === 0) {
      chipsWrap.classList.add('is-invalid');
      chipsError.hidden = false;
      valid = false;
    } else {
      chipsWrap.classList.remove('is-invalid');
      chipsError.hidden = true;
    }

    if (!valid) return;

    // Build message
    const lines = [
      `Hi Likhitha, this is ${name}.`,
      "I'd love to know more about:",
      ...selected.map(c => `• ${c}`),
    ];
    const message = lines.join('\n');
    const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;

    window.open(url, '_blank', 'noopener,noreferrer');
    closePanel();

    // Reset form
    form.reset();
    chips.forEach(c => c.setAttribute('aria-pressed', 'false'));
  });

  // Clear name error on input
  nameInput.addEventListener('input', () => {
    if (nameInput.value.trim()) {
      nameInput.classList.remove('is-invalid');
      nameError.hidden = true;
    }
  });

  // ── Programmatic API ────────────────────────────
  window.openWhatsApp = function(option) {
    window.dispatchEvent(new CustomEvent('open-whatsapp', { detail: { option: option } }));
  };

  window.addEventListener('open-whatsapp', function(e) {
    const opt = e.detail && e.detail.option;
    if (panel.getAttribute('aria-hidden') !== 'false') {
      openPanel(opt);
    } else if (opt) {
      const target = Array.from(chips).find(c => c.dataset.option === opt);
      if (target) target.setAttribute('aria-pressed', 'true');
    }
  });
</script>
