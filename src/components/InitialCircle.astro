---
interface Props {
  initials: string;
  color?: string;
  size?: number;
}
const {
  initials,
  color = '#C99A4B',
  size = 56,
} = Astro.props;

const fontSize = Math.round(size * 0.38);
---

<div
  class="initial-circle inline-flex items-center justify-center rounded-full select-none flex-shrink-0"
  style={`width:${size}px; height:${size}px; background:${color};`}
  aria-hidden="true"
>
  <span
    class="font-display font-medium text-cream"
    style={`font-size:${fontSize}px; line-height:1;`}
  >
    {initials.slice(0, 2)}
  </span>
</div>
