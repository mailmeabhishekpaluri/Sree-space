---
interface Props {
  eyebrow?: string;
  headline: string;
  headlineAccent?: string;
  sub: string;
  primaryCta?: { label: string; href?: string; onclick?: string };
  secondaryCta?: { label: string; href: string };
  image: string;
  imageAlt?: string;
  /** Attribution line in script font */
  attribution?: string;
}

const {
  eyebrow,
  headline,
  headlineAccent,
  sub,
  primaryCta,
  secondaryCta,
  image,
  imageAlt = '',
  attribution,
} = Astro.props;
---

<section class="relative min-h-[90vh] flex items-end md:items-center overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Cream scrim — opaque left, fades to transparent right (WCAG AA: ink on cream = 16.8:1) -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(105deg, rgba(var(--color-cream-rgb),0.97) 0%, rgba(var(--color-cream-rgb),0.93) 30%, rgba(var(--color-cream-rgb),0.60) 52%, rgba(var(--color-cream-rgb),0.15) 70%, transparent 85%);"
      aria-hidden="true"
    ></div>
    <!-- Bottom fade for text legibility on mobile -->
    <div
      class="absolute bottom-0 left-0 right-0 h-40 md:hidden"
      style="background: linear-gradient(to top, rgba(var(--color-cream-rgb),0.92) 0%, transparent 100%);"
      aria-hidden="true"
    ></div>
  </div>

  <!-- Content -->
  <div class="relative site-container py-24 md:py-32 w-full">
    <div class="max-w-[52ch]">
      {eyebrow && (
        <p class="font-script text-saffron mb-4" style="font-size:20px; letter-spacing:0.04em;">
          {eyebrow}
        </p>
      )}

      <h1 class="font-display text-4xl md:text-hero font-medium leading-tight text-forest mb-6">
        {headline}
        {headlineAccent && (
          <span class="text-gold"> {headlineAccent}</span>
        )}
      </h1>

      <p class="font-body text-base md:text-lg text-ink mb-8 max-w-[48ch]">
        {sub}
      </p>

      {(primaryCta || secondaryCta) && (
        <div class="flex flex-wrap gap-4 items-center">
          {primaryCta && (
            primaryCta.onclick ? (
              <button
                type="button"
                onclick={primaryCta.onclick}
                class="inline-block font-body font-medium text-forest bg-gold hover:bg-gold-dark rounded-pill transition-colors duration-200"
                style="padding:14px 28px; font-size:15px; cursor:pointer; border:none;"
              >
                {primaryCta.label}
              </button>
            ) : (
              <a
                href={primaryCta.href}
                class="inline-block font-body font-medium text-forest bg-gold hover:bg-gold-dark rounded-pill transition-colors duration-200"
                style="padding:14px 28px; font-size:15px;"
              >
                {primaryCta.label}
              </a>
            )
          )}
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class="inline-flex items-center gap-2 font-body font-medium text-forest hover:text-gold transition-colors duration-200"
              style="font-size:15px;"
            >
              {secondaryCta.label}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}
        </div>
      )}

      {attribution && (
        <p class="mt-8 font-script text-lg text-forest/70">{attribution}</p>
      )}
    </div>
  </div>
</section>
