---
interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}
const { class: cls = '', size = 'md' } = Astro.props;
const sizes = { sm: 'h-8', md: 'h-10', lg: 'h-14' };
---

<a href="/" aria-label="Sree Space — home" class:list={['inline-flex items-center', cls]}>
  <img
    src="/images/branding/logo.png"
    alt="Sree Space"
    class:list={[sizes[size], 'w-auto object-contain']}
    loading="eager"
    decoding="async"
  />
</a>
