---
interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg';
  blend?: boolean;
}
const { class: cls = '', size = 'md', blend = false } = Astro.props;
const sizes = { sm: 'h-10', md: 'h-14', lg: 'h-16' };
---

<a href="/" aria-label="Sree Space — home" class:list={['inline-flex items-center', cls]}>
  <img
    src="/images/branding/logo.png"
    alt="Sree Space"
    class:list={[sizes[size], 'w-auto object-contain', blend && 'mix-blend-multiply']}
    loading="eager"
    decoding="async"
  />
</a>
