---
import { testimonials } from '../data/testimonials';
import DevanagariMark from './DevanagariMark.astro';
import Watercolor from './Watercolor.astro';

const offeringLabel: Record<string, string> = {
  yoga:         'Yoga',
  'hands-on':   'Hands-on Therapy',
  talk:         'Talk Energy Clearance',
  consultation: 'Consultation',
};

// Only confirmed personal photos — keyed by testimonial id
const photoMap: Record<string, string> = {
  'pragathi': '/images/testimonials/01_pragathi_whatsapp_digeesha_relaxation.jpeg',
};

// Derive a 1–2 char initial for the avatar fallback
function initial(name: string): string {
  if (name.startsWith('A long')) return '—';
  return name.charAt(0).toUpperCase();
}
---

<section class="tsl-section relative overflow-hidden bg-sage-wash section-pad" aria-label="Student testimonials">

  <!-- Ambient textures -->
  <Watercolor position="top-left"    opacity={0.28} variant={2} />
  <Watercolor position="bottom-right" opacity={0.22} variant={1} />
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" aria-hidden="true">
    <DevanagariMark size={540} opacity={0.04} color="#2C5F3F" />
  </div>

  <div class="site-container relative z-10">

    <!-- Section eyebrow + headline -->
    <div class="tsl-header">
      <p class="font-script text-saffron" style="font-size:20px; letter-spacing:0.04em;">What students say</p>
      <h2 class="font-display text-forest tsl-headline" style="font-size:clamp(2.2rem,4.5vw,3.2rem); line-height:1.1; font-weight:500;">
        Their words, unedited.
      </h2>
    </div>

    <!-- Spotlight stage -->
    <div class="tsl-stage" id="tsl-stage" aria-live="polite" aria-atomic="false">

      {testimonials.map((t, i) => {
        const photo = photoMap[t.id];
        const tag   = offeringLabel[t.offerings[0]];
        const isAnon = t.id === 'anonymous-yoga';
        return (
          <div
            class={`tsl-item${i === 0 ? ' is-active' : ''}`}
            id={`tsl-item-${i}`}
            aria-hidden={i !== 0 ? 'true' : 'false'}
            data-index={i}
          >
            <!-- Decorative opening quote mark -->
            <div class="tsl-quotemarks font-display" aria-hidden="true">"</div>

            <!-- The quote -->
            <blockquote class="tsl-quote font-display">
              <p>{t.quote}</p>
            </blockquote>

            <!-- Thin gold rule -->
            <div class="tsl-rule" aria-hidden="true"></div>

            <!-- Attribution row -->
            <footer class="tsl-attr">
              <div class="tsl-avatar" aria-hidden="true">
                {photo
                  ? <img src={photo} alt={t.name} class="tsl-avatar-img" loading="lazy" decoding="async" />
                  : <span class="tsl-avatar-initial font-script">{initial(t.name)}</span>
                }
              </div>
              <div class="tsl-attr-text">
                <cite class="tsl-name font-script not-italic">
                  {t.name}{t.role ? `, ${t.role}` : ''}
                </cite>
                <span class="tsl-tag font-body">{tag}</span>
              </div>
            </footer>
          </div>
        );
      })}

    </div><!-- /tsl-stage -->

    <!-- Navigation -->
    <nav class="tsl-nav" aria-label="Navigate testimonials">
      <button class="tsl-arrow tsl-prev" id="tsl-prev" aria-label="Previous testimonial" type="button">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12.5 4L7 10l5.5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="tsl-dots" role="tablist" aria-label="Testimonial selector">
        {testimonials.map((t, i) => (
          <button
            class={`tsl-dot${i === 0 ? ' active' : ''}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`tsl-item-${i}`}
            aria-label={`View testimonial from ${t.id === 'anonymous-yoga' ? 'anonymous student' : t.name}`}
            data-dot={i}
            type="button"
          ></button>
        ))}
      </div>

      <button class="tsl-arrow tsl-next" id="tsl-next" aria-label="Next testimonial" type="button">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7.5 4L13 10l-5.5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </nav>

    <!-- "Read all" link -->
    <p class="tsl-readall text-center">
      <a href="/testimonials" class="font-body font-medium text-forest hover:text-gold transition-colors duration-200" style="font-size:14px; text-decoration:underline; text-underline-offset:4px; text-decoration-color:rgba(var(--color-gold-rgb,201,154,75),0.5);">
        Read all five voices →
      </a>
    </p>

  </div>
</section>


<style>
  /* ── Section shell ───────────────────────────────────────── */
  .tsl-section {
    --tsl-max: 680px;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .tsl-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 3.5rem;
  }

  /* ── Stage ───────────────────────────────────────────────── */
  .tsl-stage {
    max-width: var(--tsl-max);
    margin-inline: auto;
    min-height: 280px; /* prevents layout jump on short quotes */
    position: relative;
  }

  /* ── Testimonial items ───────────────────────────────────── */
  .tsl-item {
    display: none;
    text-align: center;
  }

  .tsl-item.is-active {
    display: block;
  }

  .tsl-item.is-entering {
    animation: tslFadeIn 550ms cubic-bezier(0.22, 0.58, 0.16, 1) forwards;
  }

  @keyframes tslFadeIn {
    from { opacity: 0; transform: translateY(10px); filter: blur(4px); }
    to   { opacity: 1; transform: translateY(0);    filter: blur(0px); }
  }

  /* ── Decorative quote mark ───────────────────────────────── */
  .tsl-quotemarks {
    font-size: clamp(5rem, 10vw, 8rem);
    line-height: 0.7;
    color: var(--color-gold);
    opacity: 0.55;
    margin-bottom: 0.5rem;
    font-style: italic;
    user-select: none;
  }

  /* ── Quote text ──────────────────────────────────────────── */
  .tsl-quote {
    font-style: italic;
    color: var(--color-forest);
    font-size: clamp(1.2rem, 2.2vw, 1.625rem);
    line-height: 1.55;
    margin: 0 0 1.75rem;
    padding: 0;
    max-width: 58ch;
    margin-inline: auto;
  }

  /* ── Gold rule ───────────────────────────────────────────── */
  .tsl-rule {
    width: 2rem;
    height: 1px;
    background: var(--color-gold);
    opacity: 0.65;
    margin: 0 auto 1.75rem;
  }

  /* ── Attribution ─────────────────────────────────────────── */
  .tsl-attr {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Avatar circle */
  .tsl-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(var(--color-sage-rgb), 0.8);
    background: rgba(var(--color-forest-rgb), 0.06);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tsl-avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .tsl-avatar-initial {
    font-size: 18px;
    color: rgba(var(--color-forest-rgb), 0.55);
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Name + tag stack */
  .tsl-attr-text {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-align: left;
  }

  .tsl-name {
    font-size: 20px;
    color: var(--color-gold);
    letter-spacing: 0.02em;
    display: block;
    line-height: 1;
  }

  .tsl-tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-forest);
    background: rgba(var(--color-forest-rgb), 0.07);
    border: 1px solid rgba(var(--color-forest-rgb), 0.15);
    border-radius: 9999px;
    padding: 3px 10px;
    display: inline-block;
    line-height: 1.6;
  }

  /* ── Navigation ──────────────────────────────────────────── */
  .tsl-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 2.75rem;
  }

  /* Arrows */
  .tsl-arrow {
    background: none;
    border: 1px solid rgba(var(--color-sage-rgb), 0.8);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-forest);
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
  }

  .tsl-arrow:hover {
    border-color: var(--color-gold);
    background: rgba(var(--color-gold-rgb, 201, 154, 75), 0.08);
    color: var(--color-gold);
  }

  /* Dots */
  .tsl-dots {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tsl-dot {
    appearance: none;
    background: rgba(var(--color-forest-rgb), 0.22);
    border: none;
    border-radius: 9999px;
    width: 6px;
    height: 6px;
    padding: 0;
    cursor: pointer;
    transition: width 0.3s ease, background 0.3s ease, opacity 0.3s ease;
  }

  .tsl-dot.active {
    background: var(--color-gold);
    width: 22px;
  }

  /* "Read all" link row */
  .tsl-readall {
    margin-top: 2rem;
  }

  /* ── Reduced motion ──────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .tsl-item.is-entering {
      animation: none;
    }
  }
</style>


<script>
  (() => {
    const TOTAL = 5;
    let current = 0;

    const stage  = document.getElementById('tsl-stage');
    if (!stage) return;

    const items  = stage.querySelectorAll<HTMLElement>('.tsl-item');
    const dots   = document.querySelectorAll<HTMLButtonElement>('.tsl-dot');
    const prev   = document.getElementById('tsl-prev') as HTMLButtonElement | null;
    const next   = document.getElementById('tsl-next') as HTMLButtonElement | null;

    function goTo(index: number) {
      if (index === current) return;

      // Hide current
      const outgoing = items[current];
      outgoing.classList.remove('is-active', 'is-entering');
      outgoing.setAttribute('aria-hidden', 'true');
      dots[current].classList.remove('active');
      dots[current].setAttribute('aria-selected', 'false');

      current = (index + TOTAL) % TOTAL;

      // Show new
      const incoming = items[current];
      incoming.classList.add('is-active');
      incoming.setAttribute('aria-hidden', 'false');
      // Trigger animation on next frame so display:block has settled
      requestAnimationFrame(() => {
        incoming.classList.add('is-entering');
      });
      dots[current].classList.add('active');
      dots[current].setAttribute('aria-selected', 'true');
    }

    // Dot clicks
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = parseInt(dot.dataset['dot'] ?? '0', 10);
        goTo(idx);
      });
    });

    // Arrow clicks
    prev?.addEventListener('click', () => goTo(current - 1));
    next?.addEventListener('click', () => goTo(current + 1));

    // Keyboard: left/right within the section
    stage.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft')  { goTo(current - 1); e.preventDefault(); }
      if (e.key === 'ArrowRight') { goTo(current + 1); e.preventDefault(); }
    });

    // Touch / swipe
    let touchStartX = 0;
    stage.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].clientX;
    }, { passive: true });
    stage.addEventListener('touchend', (e: TouchEvent) => {
      const delta = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(delta) > 40) goTo(delta < 0 ? current + 1 : current - 1);
    }, { passive: true });
  })();
</script>
