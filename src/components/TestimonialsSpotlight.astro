---
import { testimonials } from '../data/testimonials';
import DevanagariMark from './DevanagariMark.astro';
import Watercolor from './Watercolor.astro';

const offeringLabel: Record<string, string> = {
  yoga:         'Yoga',
  'hands-on':   'Hands-on Therapy',
  talk:         'Talk Energy Clearance',
  consultation: 'Consultation',
};

const photoMap: Record<string, string> = {
  'pragathi': '/images/testimonials/01_pragathi_whatsapp_digeesha_relaxation.jpeg',
};

function initial(name: string): string {
  if (name.startsWith('A long')) return '—';
  return name.charAt(0).toUpperCase();
}

const TOTAL = testimonials.length;
---

<section class="tsl-section relative overflow-hidden bg-sage-wash section-pad" aria-label="Testimonials">

  <!-- Ambient textures -->
  <Watercolor position="top-left"     opacity={0.28} variant={2} />
  <Watercolor position="bottom-right" opacity={0.22} variant={1} />
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" aria-hidden="true">
    <DevanagariMark size={540} opacity={0.04} color="#2C5F3F" />
  </div>

  <div class="site-container relative z-10">

    <!-- Header -->
    <div class="tsl-header">
      <p class="font-script text-saffron" style="font-size:20px; letter-spacing:0.04em;">What people say</p>
      <h2 class="font-display text-forest" style="font-size:clamp(2.2rem,4.5vw,3.2rem); line-height:1.1; font-weight:500;">
        Their words, unedited.
      </h2>
    </div>

    <!-- Stage — single card on mobile, 2-card side-by-side on desktop -->
    <div class="tsl-stage" id="tsl-stage" aria-live="polite" aria-atomic="false">

      {testimonials.map((t, i) => {
        const photo = photoMap[t.id];
        const tag   = offeringLabel[t.offerings[0]];
        return (
          <div
            class={`tsl-item${i === 0 ? ' is-active is-main' : ''}`}
            id={`tsl-item-${i}`}
            aria-hidden={i !== 0 ? 'true' : 'false'}
            data-index={i}
          >
            <!-- Card shell -->
            <div class="tsl-card">

              <!-- Decorative quote mark -->
              <div class="tsl-quotemarks font-display" aria-hidden="true">"</div>

              <!-- Quote -->
              <blockquote class="tsl-quote font-display">
                <p>{t.quote}</p>
              </blockquote>

              <!-- Thin gold rule -->
              <div class="tsl-rule" aria-hidden="true"></div>

              <!-- Attribution -->
              <footer class="tsl-attr">
                <div class="tsl-avatar" aria-hidden="true">
                  {photo
                    ? <img src={photo} alt={t.name} class="tsl-avatar-img" loading="lazy" decoding="async" />
                    : <span class="tsl-avatar-initial font-script">{initial(t.name)}</span>
                  }
                </div>
                <div class="tsl-attr-text">
                  <cite class="tsl-name font-script not-italic">
                    {t.name}{t.role ? `, ${t.role}` : ''}
                  </cite>
                  <span class="tsl-tag font-body">{tag}</span>
                </div>
              </footer>

            </div><!-- /tsl-card -->
          </div>
        );
      })}

    </div><!-- /tsl-stage -->

    <!-- Navigation -->
    <nav class="tsl-nav" aria-label="Navigate testimonials">
      <button class="tsl-arrow tsl-prev" id="tsl-prev" aria-label="Previous testimonial" type="button">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12.5 4L7 10l5.5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="tsl-dots" role="tablist" aria-label="Testimonial selector" id="tsl-dots">
        {testimonials.map((t, i) => (
          <button
            class={`tsl-dot${i === 0 ? ' active' : ''}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`tsl-item-${i}`}
            aria-label={`View testimonial from ${t.id === 'anonymous-yoga' ? 'anonymous student' : t.name}`}
            data-dot={i}
            type="button"
            tabindex={i === 0 ? '0' : '-1'}
          ></button>
        ))}
      </div>

      <button class="tsl-arrow tsl-next" id="tsl-next" aria-label="Next testimonial" type="button">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7.5 4L13 10l-5.5 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </nav>

    <!-- "Read all" link -->
    <p class="tsl-readall text-center">
      <a href="/testimonials" class="font-body font-medium text-forest hover:text-gold transition-colors duration-200" style="font-size:14px; text-decoration:underline; text-underline-offset:4px; text-decoration-color:rgba(var(--color-gold-rgb,201,154,75),0.5);">
        Read all five voices →
      </a>
    </p>

  </div>
</section>


<style>
  /* ── Section / layout vars ───────────────────────────────── */
  .tsl-section {
    --tsl-radius: 20px;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .tsl-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  /* ── Stage ───────────────────────────────────────────────── */
  .tsl-stage {
    display: flex;
    gap: 1.25rem;
    /* single-card viewport clip */
    overflow: hidden;
    position: relative;
  }

  /* ── Slide items ─────────────────────────────────────────── */
  .tsl-item {
    /* hidden by default */
    display: none;
    flex: 0 0 100%;
    min-width: 0;
  }

  /* Mobile: one card at a time */
  .tsl-item.is-main {
    display: block;
  }

  /* Desktop: second card visible alongside main */
  @media (min-width: 900px) {
    .tsl-stage {
      overflow: visible; /* let cards show side-by-side */
      max-width: 960px;
      margin-inline: auto;
      align-items: stretch;
    }

    .tsl-item.is-secondary {
      display: block;
      flex: 0 0 calc(50% - 0.625rem);
    }

    .tsl-item.is-main {
      flex: 0 0 calc(50% - 0.625rem);
    }
  }

  /* Fade-in animation for entering card */
  .tsl-item.is-entering {
    animation: tslFadeIn 500ms var(--ease-brand) forwards;
  }

  @keyframes tslFadeIn {
    from { opacity: 0; transform: translateY(8px); filter: blur(3px); }
    to   { opacity: 1; transform: translateY(0);   filter: blur(0); }
  }

  /* ── Card shell ──────────────────────────────────────────── */
  .tsl-card {
    background: var(--color-cream);
    border: 1px solid rgba(var(--color-sage-rgb), 0.55);
    border-radius: var(--tsl-radius);
    padding: 2.5rem 2.75rem;
    box-shadow:
      0 4px 16px rgba(var(--color-forest-rgb), 0.07),
      0 1px 4px  rgba(var(--color-forest-rgb), 0.04);
    text-align: center;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .tsl-item.is-main .tsl-card {
    /* primary card: gold left accent strip */
    border-left: 3px solid rgba(var(--color-gold-rgb, 201,154,75), 0.55);
    box-shadow:
      0 8px 32px rgba(var(--color-forest-rgb), 0.10),
      0 2px 8px  rgba(var(--color-forest-rgb), 0.05);
  }

  .tsl-stage:hover .tsl-card {
    /* subtle lift on hover to signal pause */
    box-shadow:
      0 12px 40px rgba(var(--color-forest-rgb), 0.12),
      0 2px 8px   rgba(var(--color-forest-rgb), 0.06);
  }

  /* secondary card: slightly muted */
  .tsl-item.is-secondary .tsl-card {
    opacity: 0.72;
  }

  /* ── Decorative quote mark ───────────────────────────────── */
  .tsl-quotemarks {
    font-size: clamp(4rem, 8vw, 6.5rem);
    line-height: 0.65;
    color: var(--color-gold);
    opacity: 0.5;
    margin-bottom: 0.25rem;
    font-style: italic;
    user-select: none;
  }

  /* ── Quote text ──────────────────────────────────────────── */
  .tsl-quote {
    font-style: italic;
    color: var(--color-forest);
    font-size: clamp(1.05rem, 2vw, 1.4rem);
    line-height: 1.6;
    margin: 0 0 1.5rem;
    padding: 0;
    flex: 1; /* pushes attribution to bottom */
  }

  /* ── Gold rule ───────────────────────────────────────────── */
  .tsl-rule {
    width: 2rem;
    height: 1px;
    background: var(--color-gold);
    opacity: 0.6;
    margin: 0 auto 1.5rem;
    flex-shrink: 0;
  }

  /* ── Attribution ─────────────────────────────────────────── */
  .tsl-attr {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .tsl-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(var(--color-sage-rgb), 0.8);
    background: rgba(var(--color-forest-rgb), 0.06);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tsl-avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .tsl-avatar-initial {
    font-size: 17px;
    color: rgba(var(--color-forest-rgb), 0.55);
    line-height: 1;
  }

  .tsl-attr-text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-align: left;
  }

  .tsl-name {
    font-size: 18px;
    color: var(--color-gold);
    letter-spacing: 0.02em;
    display: block;
    line-height: 1;
  }

  .tsl-tag {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-forest);
    background: rgba(var(--color-forest-rgb), 0.07);
    border: 1px solid rgba(var(--color-forest-rgb), 0.14);
    border-radius: 9999px;
    padding: 3px 9px;
    display: inline-block;
    line-height: 1.6;
  }

  /* ── Navigation ──────────────────────────────────────────── */
  .tsl-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 2.25rem;
  }

  .tsl-arrow {
    background: none;
    border: 1px solid rgba(var(--color-sage-rgb), 0.8);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-forest);
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
    flex-shrink: 0;
  }

  .tsl-arrow:hover {
    border-color: var(--color-gold);
    background: rgba(var(--color-gold-rgb, 201,154,75), 0.08);
    color: var(--color-gold);
  }

  /* Dots */
  .tsl-dots {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tsl-dot {
    appearance: none;
    background: rgba(var(--color-forest-rgb), 0.22);
    border: none;
    border-radius: 9999px;
    width: 6px;
    height: 6px;
    /* WCAG 2.5.5: pad click target to ≥24px without growing visual dot */
    padding: 9px 3px;
    cursor: pointer;
    transition: width 0.3s ease, background 0.3s ease;
    background-clip: content-box;
    box-sizing: content-box;
  }

  .tsl-dot.active {
    background: var(--color-gold);
    background-clip: content-box;
    width: 22px;
  }

  /* "Read all" link */
  .tsl-readall {
    margin-top: 1.75rem;
  }

  /* ── Reduced motion ──────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .tsl-item.is-entering { animation: none; }
    .tsl-card { transition: none; }
  }
</style>


<script>
  (() => {
    const TOTAL = 5;
    const INTERVAL = 5500; // ms between auto-advances
    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    const stage        = document.getElementById('tsl-stage');
    if (!stage) return;

    const items        = stage.querySelectorAll<HTMLElement>('.tsl-item');
    const dots         = document.querySelectorAll<HTMLButtonElement>('.tsl-dot');
    const prevBtn      = document.getElementById('tsl-prev') as HTMLButtonElement | null;
    const nextBtn      = document.getElementById('tsl-next') as HTMLButtonElement | null;
    const dotsContainer = document.getElementById('tsl-dots');

    // ── Determine if desktop 2-card mode is active ──────────
    const isDesktop = () => window.innerWidth >= 900;

    // ── Core slide transition ────────────────────────────────
    function goTo(index: number, moveFocus = false) {
      const next = (index + TOTAL) % TOTAL;
      if (next === current) return;

      // Deactivate outgoing
      const outgoing = items[current];
      outgoing.classList.remove('is-active', 'is-main', 'is-secondary', 'is-entering');
      outgoing.setAttribute('aria-hidden', 'true');
      dots[current].classList.remove('active');
      dots[current].setAttribute('aria-selected', 'false');
      dots[current].setAttribute('tabindex', '-1');

      // Deactivate previous secondary (if desktop)
      if (isDesktop()) {
        const prevSecondary = items[(current + 1) % TOTAL];
        prevSecondary.classList.remove('is-active', 'is-main', 'is-secondary', 'is-entering');
        prevSecondary.setAttribute('aria-hidden', 'true');
      }

      current = next;

      // Activate incoming main
      const incoming = items[current];
      incoming.classList.add('is-active', 'is-main');
      incoming.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(() => incoming.classList.add('is-entering'));

      // Activate secondary on desktop
      if (isDesktop()) {
        const secondary = items[(current + 1) % TOTAL];
        secondary.classList.add('is-active', 'is-secondary');
        secondary.setAttribute('aria-hidden', 'false');
        requestAnimationFrame(() => secondary.classList.add('is-entering'));
      }

      // Update dots
      dots[current].classList.add('active');
      dots[current].setAttribute('aria-selected', 'true');
      dots[current].setAttribute('tabindex', '0');
      if (moveFocus) dots[current].focus();
    }

    // ── Bootstrap desktop secondary on load ─────────────────
    function initDesktopSecondary() {
      if (!isDesktop()) return;
      const secondary = items[(current + 1) % TOTAL];
      secondary.classList.add('is-active', 'is-secondary');
      secondary.setAttribute('aria-hidden', 'false');
    }
    initDesktopSecondary();

    // ── Auto-rotation ────────────────────────────────────────
    function startTimer() {
      timer = setInterval(() => goTo(current + 1), INTERVAL);
    }
    function stopTimer() {
      if (timer !== null) { clearInterval(timer); timer = null; }
    }

    startTimer();

    // Pause on hover (entire stage including cards)
    stage.addEventListener('mouseenter', stopTimer);
    stage.addEventListener('mouseleave', startTimer);

    // Pause on focus-within (keyboard users navigating inside)
    stage.addEventListener('focusin',  stopTimer);
    stage.addEventListener('focusout', (e) => {
      if (!stage.contains(e.relatedTarget as Node)) startTimer();
    });

    // ── Dot clicks ───────────────────────────────────────────
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        stopTimer();
        goTo(parseInt(dot.dataset['dot'] ?? '0', 10));
        startTimer();
      });
    });

    // ── Arrow-key nav within tablist ─────────────────────────
    dotsContainer?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft')  { stopTimer(); goTo(current - 1, true); startTimer(); e.preventDefault(); }
      if (e.key === 'ArrowRight') { stopTimer(); goTo(current + 1, true); startTimer(); e.preventDefault(); }
    });

    // ── Prev / next buttons ───────────────────────────────────
    prevBtn?.addEventListener('click', () => { stopTimer(); goTo(current - 1); startTimer(); });
    nextBtn?.addEventListener('click', () => { stopTimer(); goTo(current + 1); startTimer(); });

    // ── Swipe support ─────────────────────────────────────────
    let touchStartX = 0;
    stage.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].clientX;
      stopTimer();
    }, { passive: true });
    stage.addEventListener('touchend', (e: TouchEvent) => {
      const delta = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(delta) > 40) goTo(delta < 0 ? current + 1 : current - 1);
      startTimer();
    }, { passive: true });

    // ── Re-init on resize (desktop ↔ mobile breakpoint) ──────
    let resizeTimeout: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        // Ensure secondary visibility matches current breakpoint
        items.forEach((item, i) => {
          if (i === current) return; // leave main alone
          const shouldBeSecondary = isDesktop() && i === (current + 1) % TOTAL;
          if (shouldBeSecondary) {
            item.classList.add('is-active', 'is-secondary');
            item.setAttribute('aria-hidden', 'false');
          } else if (!item.classList.contains('is-main')) {
            item.classList.remove('is-active', 'is-main', 'is-secondary', 'is-entering');
            item.setAttribute('aria-hidden', 'true');
          }
        });
      }, 150);
    }, { passive: true });
  })();
</script>
