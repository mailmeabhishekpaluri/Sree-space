---
interface Props {
  src: string;
  alt: string;
  framed?: boolean;
  class?: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
}
const {
  src,
  alt,
  framed = false,
  class: cls = '',
  width,
  height,
  loading = 'lazy',
} = Astro.props;
---

<div class:list={['treated-photo-wrap relative overflow-hidden', framed && 'treated-photo-framed', cls]}>
  <!-- Cream matte + gold frame (when framed) is handled via CSS -->
  <img
    {src}
    {alt}
    class="treated-photo-img w-full h-full object-cover"
    {loading}
    decoding="async"
    {...(width  ? { width }  : {})}
    {...(height ? { height } : {})}
  />
  <!-- Sage multiply overlay -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: var(--color-sage); opacity: 0.08; mix-blend-mode: multiply;"
    aria-hidden="true"
  ></div>
  <!-- Radial vignette -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at center, transparent 50%, rgba(var(--color-ink-rgb),0.12) 100%);"
    aria-hidden="true"
  ></div>
</div>

<style>
  .treated-photo-img {
    filter: saturate(0.78) brightness(0.96);
    display: block;
  }

  /* Framed: 4px cream matte + 1px gold inner border */
  .treated-photo-framed {
    padding: 4px;
    background: var(--color-cream);
    outline: 1px solid var(--color-gold);
    outline-offset: -1px;
  }
</style>
