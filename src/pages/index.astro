---
import Base from '../layouts/Base.astro';
import DevanagariMark from '../components/DevanagariMark.astro';
import Ornament from '../components/Ornament.astro';
import Watercolor from '../components/Watercolor.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import OfferingCard from '../components/OfferingCard.astro';
import TestimonialsSpotlight from '../components/TestimonialsSpotlight.astro';
import { site } from '../data/site';
---

<Base>
  <!-- ─── HERO ──────────────────────────────────────────────────── -->
  <section class="hero relative min-h-screen flex items-center overflow-hidden">

    <!-- Ken Burns photo -->
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/yoga-poses/03_riverside_sunset_prayer_patchwork_dress.jpeg"
        alt="Likhitha Sree in prayer at riverside sunset"
        class="kenburns w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <!-- Sage → transparent mask, left 40% -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(100deg, rgba(var(--color-sage-rgb),0.92) 0%, rgba(var(--color-sage-rgb),0.80) 25%, rgba(var(--color-sage-rgb),0.50) 45%, rgba(var(--color-sage-rgb),0.10) 65%, transparent 80%);"
        aria-hidden="true"
      ></div>
      <!-- Bottom vignette for mobile legibility -->
      <div
        class="absolute bottom-0 left-0 right-0 h-48 md:hidden"
        style="background: linear-gradient(to top, rgba(var(--color-sage-rgb),0.7) 0%, transparent 100%);"
        aria-hidden="true"
      ></div>
    </div>

    <!-- Devanagari watermark — center-left -->
    <div class="absolute left-[2%] top-1/2 -translate-y-1/2 pointer-events-none select-none" aria-hidden="true">
      <DevanagariMark size={480} opacity={0.10} color="#2C5F3F" />
    </div>

    <!-- Content -->
    <div class="relative site-container py-32 md:py-40 w-full">
      <div class="max-w-[54ch]">

        <!-- Eyebrow in Caveat script, saffron -->
        <p
          class="font-script text-saffron mb-5 hero-eyebrow"
          style="font-size:24px; opacity:0; transform:translateY(10px); transition:opacity 0.6s ease, transform 0.6s ease;"
        >
          True empowerment as key
        </p>

        <!-- Headline -->
        <h1
          id="hero-headline"
          class="font-display font-medium text-cream leading-tight mb-6"
          style="font-size: clamp(3.5rem, 8vw, 6rem); line-height:1.05;"
          aria-label="Come home to yourself."
        >
          <span class="hero-word">Come</span>
          <span class="hero-word"> home</span>
          <span class="hero-word"> to</span>
          <span class="hero-word"> <em class="not-italic italic">yourself</em></span><span class="hero-word">.</span>
        </h1>

        <!-- Hand-drawn gold underline under "yourself" — draws on after the word reveals -->
        <div class="mb-8 -mt-4 ml-[calc(3ch)]" aria-hidden="true">
          <svg width="200" height="14" viewBox="0 0 200 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path class="hero-underline-path"
              d="M3 9 C30 4 55 13 85 7 C115 2 138 11 165 6 C178 4 190 8 197 6"
              stroke="#C99A4B" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </div>

        <!-- Sub -->
        <p
          class="font-body text-cream/90 mb-10 hero-sub"
          style="font-size:19px; max-width:52ch; opacity:0; transform:translateY(10px); transition:opacity 0.7s ease 0.55s, transform 0.7s ease 0.55s;"
        >
          Yoga, hands-on energy work, and consciousness practices —
          guided by Likhitha Sree.
        </p>

        <!-- CTAs -->
        <div
          class="flex flex-wrap gap-5 items-center hero-ctas"
          style="opacity:0; transform:translateY(10px); transition:opacity 0.7s ease 0.75s, transform 0.7s ease 0.75s;"
        >
          <!-- Primary: gold fill, forest text, pill -->
          <a
            href="/monday"
            class="font-body font-medium text-forest bg-gold rounded-pill transition-all duration-200 hover:bg-gold-dark"
            style="padding:16px 32px; font-size:15px; letter-spacing:0.01em;"
          >
            Join the free Monday Night Call
          </a>
          <!-- Secondary: cream underline + animated arrow -->
          <a
            href="/offerings"
            class="group font-body font-medium text-cream underline decoration-cream/50 underline-offset-4 hover:decoration-gold transition-all duration-200 flex items-center gap-2"
            style="font-size:15px;"
          >
            Explore offerings
            <svg
              width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
              class="transition-transform duration-200 group-hover:translate-x-1.5"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── QUICK-FIXES / YOGA TREE ────────────────────────────── -->
  <section class="relative overflow-hidden bg-sage-wash section-pad">
    <Watercolor position="center-right" opacity={0.45} variant={2} />

    <div class="site-container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

        <!-- Left: text -->
        <ScrollReveal class="order-2 md:order-1">
          <p class="font-script text-saffron mb-4" style="font-size:20px; letter-spacing:0.04em;">
            Experience yoga as a whole
          </p>
          <h2 class="font-display text-forest mb-6" style="font-size:clamp(2.6rem,5vw,4rem); line-height:1.1; font-weight:500;">
            Your health doesn't need
            <span class="relative inline-block">
              quick fixes.
              <svg class="absolute -bottom-1 left-0 w-full" height="12" viewBox="0 0 200 12" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <path d="M3 9 C40 3 90 11 130 6 C160 3 180 9 197 6" stroke="#E07B2C" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
            </span>
          </h2>
          <p class="font-body text-ink/80 leading-relaxed mb-8" style="font-size:1.06rem; max-width:44ch;">
            From Hatha to Kundalini, from Pranayama to Kriya — yoga is a whole tree, not
            a single branch. Likhitha's practice meets you wherever you are on it.
          </p>
          <a
            href="/offerings/yoga"
            class="group inline-flex items-center gap-3 font-body text-sm font-medium text-forest hover:text-gold transition-colors duration-200"
          >
            Explore yoga offerings
            <Ornament name="swash" size={20} color="#C99A4B" class="group-hover:translate-x-1 transition-transform duration-200" />
          </a>
        </ScrollReveal>

        <!-- Right: yoga tree illustration — fades up after the text column settles -->
        <ScrollReveal duration={900} delay={120} class="order-1 md:order-2 relative flex justify-center md:justify-end">
          <!-- Watercolor wash behind the image -->
          <Watercolor position="bottom-left" opacity={0.5} variant={2} class="absolute inset-0 pointer-events-none" />
          <img
            src="/images/references/yoga_tree_design.png"
            alt="Hand-drawn yoga tree illustration showing branches of practice: Hatha, Yin/Restorative, Ashtanga Vinyasa, Kriya, Pranayama, Kundalini"
            class="w-full h-auto relative z-10"
            style="max-width:520px; border-radius:20px; box-shadow:0 8px 32px rgba(var(--color-forest-rgb),0.10), 0 2px 8px rgba(var(--color-forest-rgb),0.06);"
            loading="lazy"
            decoding="async"
          />
        </ScrollReveal>

      </div>
    </div>
  </section>

  <!-- ─── OFFERINGS GRID ───────────────────────────────────────── -->
  <section class="relative bg-cream overflow-hidden section-pad">
    <Watercolor position="bottom-right" opacity={0.28} variant={3} />

    <div class="site-container">

      <!-- Section heading -->
      <ScrollReveal>
        <div class="offerings-header">
          <p class="font-script text-saffron" style="font-size:20px; letter-spacing:0.04em;">Offerings</p>
          <h2 class="font-display text-forest" style="font-size:clamp(2.4rem,5vw,3.5rem); line-height:1.1; font-weight:500;">
            What are you asking of<br class="hidden sm:inline" /> yourself right now?
          </h2>
          <p class="font-body text-ink/70 offerings-sub" style="font-size:1.05rem; max-width:52ch; line-height:1.65;">
            Each offering begins where you are — not where a program says you should be.
          </p>
          <!-- gold thin rule -->
          <div style="width:48px; height:1px; background:var(--color-gold); margin-top:0.25rem;" aria-hidden="true"></div>
        </div>
      </ScrollReveal>

      <!-- 2×2 card grid -->
      <div class="offerings-grid">
        <ScrollReveal delay={0}>
          <OfferingCard
            title="Yoga"
            short="Movement that meets you where you are. 1:1, group, therapy, kundalini."
            slug="yoga"
            index="01"
          />
        </ScrollReveal>
        <ScrollReveal delay={80}>
          <OfferingCard
            title="Hands-on Therapy"
            short="Access Bars, Body Process, Energetic Face Lift. Quiet release."
            slug="hands-on-therapy"
            index="02"
          />
        </ScrollReveal>
        <ScrollReveal delay={160}>
          <OfferingCard
            title="Talk Energy Clearance"
            short="Conversation as energy work. The right question can move what years of silence couldn't."
            slug="talk-energy-clearance"
            index="03"
          />
        </ScrollReveal>
        <ScrollReveal delay={240}>
          <OfferingCard
            title="Consultation"
            short="Tailor-made plans drawing on yoga, mudra, kriya, and energy work."
            slug="consultation"
            index="04"
          />
        </ScrollReveal>
      </div>

      <!-- See-all link -->
      <ScrollReveal>
        <div class="offerings-footer">
          <a
            href="/offerings"
            class="group inline-flex items-center gap-3 font-body font-medium text-forest hover:text-gold transition-colors duration-200"
            style="font-size:15px;"
          >
            See all offerings
            <Ornament name="swash" size={18} color="currentColor" class="group-hover:translate-x-1 transition-transform duration-200" />
          </a>
        </div>
      </ScrollReveal>

    </div>
  </section>

  <!-- ─── TESTIMONIALS SPOTLIGHT ──────────────────────────────── -->
  <TestimonialsSpotlight />

  <!-- ─── MONDAY NIGHT CALL CTA ───────────────────────────────── -->
  <section class="relative overflow-hidden text-cream" style="min-height:560px; display:flex; align-items:center;">
    <!-- Background photo -->
    <div class="absolute inset-0" aria-hidden="true">
      <img
        src="/images/portraits/06_lakeside_crouched_dusk.jpeg"
        alt=""
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
      <!-- Forest→transparent gradient from bottom + inset vignette -->
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(var(--color-forest-rgb),0.90) 0%, rgba(var(--color-forest-rgb),0.55) 40%, rgba(var(--color-forest-rgb),0.25) 70%, transparent 100%), radial-gradient(ellipse at center, transparent 50%, rgba(var(--color-forest-rgb),0.45) 100%);"></div>
    </div>

    <!-- Lotus ornament bottom-right, faint -->
    <div class="absolute bottom-8 right-8 pointer-events-none select-none" aria-hidden="true">
      <Ornament name="lotus" size={64} color="#C99A4B" strokeWidth={1.2} class="opacity-[0.08]" />
    </div>

    <div class="relative site-container w-full text-center" style="padding-top:6rem; padding-bottom:6rem;">
      <ScrollReveal>
        <div class="max-w-[52ch] mx-auto">
          <!-- Caveat eyebrow -->
          <p class="font-script text-gold mb-4" style="font-size:22px; letter-spacing:0.03em;">
            Every Monday · 8 PM IST
          </p>
          <!-- Headline -->
          <h2 class="font-display text-cream mb-5" style="font-size:clamp(2.4rem,5vw,4rem); line-height:1.1; font-weight:500;">
            Free Monday Night Catch-Up
          </h2>
          <!-- Sub -->
          <p class="font-body leading-relaxed mb-10 text-cream/[0.88]" style="font-size:17px; max-width:52ch;">
            A weekly ritual that gently guides you back to awareness.
            Free, by design — you 'pay' by becoming a more present human.
          </p>
          <!-- CTA: gold fill, forest text, pill, hand-drawn arrow -->
          <a
            href="/monday"
            class="group inline-flex items-center gap-3 font-body font-medium text-forest bg-gold transition-all duration-200 hover:bg-gold-dark"
            style="padding:16px 36px; font-size:15px; border-radius:9999px; letter-spacing:0.01em;"
          >
            Save your seat
            <!-- Hand-drawn arrow -->
            <svg width="22" height="22" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="group-hover:translate-x-1 transition-transform duration-200">
              <path d="M10 50 C30 50 60 50 82 50"/>
              <path d="M68 36 C76 42 82 50 76 64"/>
              <path d="M62 28 C72 34 82 44 82 50 C82 56 78 64 68 70"/>
            </svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- ─── PAUSE / BRAND IDENTITY ──────────────────────────────── -->
  <section class="relative bg-cream overflow-hidden" style="padding-top:6rem; padding-bottom:6rem;">
    <Watercolor position="top-right" opacity={0.35} variant={1} />

    <div class="site-container">
      <div class="grid grid-cols-12 gap-6 items-start">

        <!-- Left: giant श्री — slow pure fade, no vertical drift (it's floating, not landing) -->
        <ScrollReveal duration={1000} y={0} class="col-span-3 flex justify-end pt-2 select-none" aria-hidden="true">
          <DevanagariMark size={320} opacity={0.60} color="#C99A4B" />
        </ScrollReveal>

        <!-- Right: content -->
        <ScrollReveal class="col-span-9 md:col-span-8 md:col-start-4">
          <!-- Eyebrow -->
          <p class="font-script text-saffron mb-4" style="font-size:20px; letter-spacing:0.04em;">
            What is Sree Space?
          </p>

          <!-- Headline -->
          <h2 class="font-display text-forest mb-4" style="font-size:clamp(2.4rem,5vw,3.5rem); line-height:1.1; font-weight:500;">
            A space where you find your own light.
          </h2>

          <!-- Swash ornament -->
          <Ornament name="swash" size={56} color="#C99A4B" class="mb-6 opacity-90" />

          <!-- Body copy -->
          <p class="font-body text-ink/80 leading-relaxed max-w-prose" style="font-size:1.06rem;">
            <em class="not-italic font-medium text-gold">Sree</em> (śrī / श्री) means ultimate
            enlightenment, prosperity, knowledge, internal light.
            <em class="not-italic font-medium text-forest">Space</em> is where anything can occur.
            Together: the room you step into to find your own light — and your path home.
          </p>
        </ScrollReveal>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ─── Hero underline draw-on ─────────────────────────── */
  /* pathLength≈210 measured from the cubic-bezier path */
  .hero-underline-path {
    stroke-dasharray:  210;
    stroke-dashoffset: 210;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-underline-path {
      /* Start after the last hero word finishes (~820ms total) */
      animation: heroUnderlineDraw 650ms var(--ease-brand) 820ms forwards;
    }
  }
  /* Reduced-motion: show the line immediately, fully drawn */
  @media (prefers-reduced-motion: reduce) {
    .hero-underline-path { stroke-dashoffset: 0; }
  }
  @keyframes heroUnderlineDraw {
    to { stroke-dashoffset: 0; }
  }

  /* ─── Offerings section ───────────────────────────────── */
  .offerings-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .offerings-sub {
    margin-top: 0.25rem;
  }

  .offerings-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .offerings-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  .offerings-footer {
    margin-top: 2.5rem;
    display: flex;
    justify-content: flex-end;
  }
</style>

<!-- ─── SCRIPTS ────────────────────────────────────────────────── -->
<script define:vars={{ phrases: site.signaturePhrases }}>
  // ── Nav transparent until scroll ──
  document.body.classList.add('nav-transparent');
  const nav = document.getElementById('site-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  }, { passive: true });

  // ── Word-by-word hero reveal (stagger 80ms) ──
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function revealHero() {
    const eyebrow = document.querySelector('.hero-eyebrow');
    if (eyebrow) { eyebrow.style.opacity = '1'; eyebrow.style.transform = 'translateY(0)'; }

    if (!reduced) {
      document.querySelectorAll('.hero-word').forEach((el, i) => {
        const e = el;
        e.style.cssText += `opacity:0; display:inline-block; transform:translateY(10px); transition:opacity 0.55s ease ${100 + i * 80}ms, transform 0.55s ease ${100 + i * 80}ms;`;
        requestAnimationFrame(() => requestAnimationFrame(() => {
          e.style.opacity = '1';
          e.style.transform = 'translateY(0)';
        }));
      });
    }

    const sub  = document.querySelector('.hero-sub');
    const ctas = document.querySelector('.hero-ctas');
    if (sub)  { sub.style.opacity  = '1'; sub.style.transform  = 'translateY(0)'; }
    if (ctas) { ctas.style.opacity = '1'; ctas.style.transform = 'translateY(0)'; }
  }

  requestAnimationFrame(() => requestAnimationFrame(revealHero));
</script>
