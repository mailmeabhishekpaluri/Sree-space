---
import Base from '../layouts/Base.astro';
import Watercolor from '../components/Watercolor.astro';
import Ornament from '../components/Ornament.astro';
import DevanagariMark from '../components/DevanagariMark.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import TreatedPhoto from '../components/TreatedPhoto.astro';
import { site } from '../data/site';

const offeringOptions = [
  { value: 'yoga',         label: 'Yoga' },
  { value: 'hands-on',     label: 'Hands-on Therapy' },
  { value: 'talk',         label: 'Talk Energy Clearance' },
  { value: 'consultation', label: 'Consultation' },
  { value: 'monday',       label: 'Monday Night Call' },
  { value: 'not-sure',     label: 'Not sure yet' },
];

const faqs = [
  {
    q: 'Do I need experience?',
    a: 'No. Sessions start where your body is. The first one is often a conversation more than a practice.',
  },
  {
    q: 'Are sessions in person or remote?',
    a: 'Both. Hands-on therapy is in person (Hyderabad). Yoga and consultations can be either. The Monday call is always remote.',
  },
  {
    q: "What's the price range?",
    a: "It varies by offering. The Monday call is always free. For everything else, write to me and we'll find something that works for you.",
  },
  {
    q: 'How long is a typical session?',
    a: '60–90 minutes for most things. Bars sessions often feel shorter than they are.',
  },
  {
    q: 'What if I need to cancel?',
    a: 'Just let me know. Life happens. No charges, no awkwardness.',
  },
];
---

<Base
  title="Contact & Book"
  description="Reach out to Likhitha Sree — no wrong door. Responses within 48 hours, personally."
>

  <!-- ═══════════════════════════════════════════════
       SECTION 1 — HERO
  ══════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center overflow-hidden">

    <!-- Background photo -->
    <div class="absolute inset-0" aria-hidden="true">
      <img
        src="/images/portraits/02_park_full_body_embroidered_shirt.jpeg"
        alt=""
        class="w-full h-full object-cover object-top"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <!-- Sage → transparent from left where type sits -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(95deg, rgba(197,211,192,0.96) 0%, rgba(197,211,192,0.85) 20%, rgba(197,211,192,0.55) 40%, rgba(197,211,192,0.15) 60%, transparent 78%);"
      ></div>
    </div>

    <!-- Devanagari watermark left-center -->
    <div class="absolute left-[1%] top-1/2 -translate-y-1/2 pointer-events-none select-none" aria-hidden="true">
      <DevanagariMark size={480} opacity={0.12} color="#2C5F3F" />
    </div>

    <div class="relative site-container py-36 md:py-48 w-full">
      <div class="grid grid-cols-12">
        <div class="col-span-12 md:col-span-7">
          <ScrollReveal>
            <p class="font-script text-saffron mb-5" style="font-size:22px; letter-spacing:0.04em;">
              Get in touch
            </p>
            <h1
              class="font-display font-medium text-cream mb-7"
              style="font-size:clamp(2.8rem, 7vw, 6rem); line-height:1.05;"
              aria-label="Ask. That's the practice."
            >
              <span class="chw">Ask.</span>
              <span class="chw"> That's</span>
              <span class="chw"> the</span>
              <span class="chw"> practice.</span>
            </h1>
            <p class="font-body mb-6"
              style="font-size:19px; max-width:56ch; line-height:1.65; color:rgba(251,248,241,0.90);">
              Whatever you're carrying, send it. There's no wrong door.
            </p>
            <p class="font-script italic text-gold" style="font-size:20px;">
              — Likhitha responds personally within 48 hours.
            </p>
          </ScrollReveal>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       SECTION 2 — FORM
  ══════════════════════════════════════════════════ -->
  <section id="contact-form" class="relative overflow-hidden section-pad" style="background:#EFF3ED;">
    <Watercolor position="top-left" opacity={0.35} variant={2} />

    <div class="site-container relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-14 items-start">

        <!-- Form — cols 1–7 -->
        <div class="lg:col-span-7">
          <ScrollReveal>
            <p class="font-script text-gold mb-3" style="font-size:20px; letter-spacing:0.04em;">Write to Likhitha</p>
            <h2 class="font-display font-medium text-forest mb-4"
              style="font-size:clamp(2.2rem,4vw,3.5rem); line-height:1.1;">
              What's on your mind?
            </h2>
            <p class="font-body text-ink/75 leading-relaxed mb-10"
              style="font-size:17px; max-width:56ch;">
              Take your time. No template, no pressure.
            </p>

            <form
              name="contact"
              method="POST"
              action="/success"
              class="flex flex-col gap-7"
              data-netlify="true"
              netlify-honeypot="bot-field"
            >
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden" aria-hidden="true">
                <label>Don't fill this: <input name="bot-field" /></label>
              </p>

              <!-- Name -->
              <div class="flex flex-col gap-2">
                <label for="c-name" class="contact-label">Name</label>
                <input
                  id="c-name"
                  name="name"
                  type="text"
                  required
                  autocomplete="name"
                  aria-required="true"
                  class="contact-input"
                  placeholder="Your name"
                />
              </div>

              <!-- Reach -->
              <div class="flex flex-col gap-2">
                <label for="c-reach" class="contact-label">Best way to reach you</label>
                <input
                  id="c-reach"
                  name="reach"
                  type="text"
                  required
                  aria-required="true"
                  class="contact-input"
                  placeholder="WhatsApp number or email"
                />
              </div>

              <!-- Message -->
              <div class="flex flex-col gap-2">
                <label for="c-message" class="contact-label">What's on your mind?</label>
                <textarea
                  id="c-message"
                  name="message"
                  rows="5"
                  class="contact-input"
                  style="resize:vertical;"
                  placeholder="Share as little or as much as you'd like."
                ></textarea>
              </div>

              <!-- Interest chips (multi-select) -->
              <fieldset>
                <legend class="contact-label mb-4">What are you drawn to?</legend>
                <div class="flex flex-wrap gap-x-6 gap-y-3" role="group">
                  {offeringOptions.map(opt => (
                    <button
                      type="button"
                      data-value={opt.value}
                      aria-pressed="false"
                      class="interest-btn font-script"
                      style="font-size:20px; background:none; border:none; cursor:pointer; padding:0.25rem 0; color:rgba(31,42,36,0.75); position:relative;"
                    >
                      {opt.label}
                    </button>
                  ))}
                </div>
                <!-- Hidden inputs populated by JS -->
                <div id="interest-hidden" aria-hidden="true"></div>
              </fieldset>

              <!-- Submit -->
              <div>
                <button
                  type="submit"
                  class="group inline-flex items-center gap-3 font-body font-medium text-forest bg-gold hover:bg-gold-dark transition-colors duration-200"
                  style="padding:16px 32px; font-size:15px; border-radius:9999px; letter-spacing:0.01em;"
                >
                  Send
                  <Ornament name="swash" size={16} color="#2C5F3F" class="group-hover:translate-x-1 transition-transform duration-200" />
                </button>
                <p class="font-script italic text-muted mt-4" style="font-size:18px;">
                  Likhitha responds personally within 48 hours. Sometimes sooner.
                </p>
              </div>
            </form>
          </ScrollReveal>
        </div>

        <!-- Warmth companion — cols 8–12 -->
        <div class="lg:col-span-5">
          <ScrollReveal delay={80}>
            <TreatedPhoto
              src="/images/portraits/04_peaceful_closeup_temple_backdrop.jpeg"
              alt="Likhitha Sree with eyes closed, soft smile, temple and mountain backdrop"
              framed
              width={500}
              height={640}
              class="w-full"
            />
            <div class="text-center mt-5">
              <p class="font-script text-forest" style="font-size:22px;">I read every one. Honestly.</p>
              <p class="font-script text-gold mt-1" style="font-size:18px;">— Likhitha</p>
              <div class="flex justify-center mt-4">
                <Ornament name="lotus" size={40} color="#C99A4B" class="opacity-70" />
              </div>
            </div>
          </ScrollReveal>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       SECTION 3 — DIRECT CONTACT METHODS
  ══════════════════════════════════════════════════ -->
  <section class="relative bg-cream overflow-hidden section-pad">
    <div class="site-container">
      <ScrollReveal>
        <p class="font-script text-saffron text-center mb-3" style="font-size:20px; letter-spacing:0.04em;">
          Or reach out directly
        </p>
        <h2 class="font-display font-medium text-forest text-center mb-14"
          style="font-size:clamp(2rem,4vw,3rem); line-height:1.1;">
          Pick whichever feels right.
        </h2>
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- WhatsApp -->
        <ScrollReveal delay={0}>
          <a
            href={site.socials.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-method-card group"
            aria-label="Contact via WhatsApp"
          >
            <div class="contact-method-icon group-hover:rotate-6">
              <Ornament name="leaf" size={32} color="#C99A4B" />
            </div>
            <h3 class="font-display text-forest mb-2" style="font-size:1.5rem; font-weight:500;">WhatsApp</h3>
            <p class="font-body text-ink/80 mb-3" style="font-size:1rem; font-variant-numeric: tabular-nums;">
              {site.socials.whatsapp.replace('https://wa.me/', '+').replace('91', '+91 ')}
            </p>
            <p class="font-script italic text-muted" style="font-size:16px;">
              Fastest for booking and quick questions
            </p>
          </a>
        </ScrollReveal>

        <!-- Instagram -->
        <ScrollReveal delay={80}>
          <a
            href={site.socials.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-method-card group"
            aria-label="Contact via Instagram"
          >
            <div class="contact-method-icon group-hover:rotate-6">
              <Ornament name="lotus" size={32} color="#C99A4B" />
            </div>
            <h3 class="font-display text-forest mb-2" style="font-size:1.5rem; font-weight:500;">Instagram</h3>
            <p class="font-body text-ink/80 mb-3" style="font-size:1rem;">
              {site.socials.instagram.replace('https://instagram.com/', '@')}
            </p>
            <p class="font-script italic text-muted" style="font-size:16px;">
              DMs welcome — happy to chat there too
            </p>
          </a>
        </ScrollReveal>

        <!-- Email -->
        <ScrollReveal delay={160}>
          <a
            href={`mailto:${site.socials.email}`}
            class="contact-method-card group"
            aria-label="Contact via Email"
          >
            <div class="contact-method-icon group-hover:rotate-6">
              <Ornament name="swash" size={32} color="#C99A4B" />
            </div>
            <h3 class="font-display text-forest mb-2" style="font-size:1.5rem; font-weight:500;">Email</h3>
            <p class="font-body text-ink/80 mb-3" style="font-size:1rem; word-break:break-all;">
              {site.socials.email}
            </p>
            <p class="font-script italic text-muted" style="font-size:16px;">
              For longer messages or attachments
            </p>
          </a>
        </ScrollReveal>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       SECTION 4 — FAQ
  ══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden section-pad" style="background:#EFF3ED;">
    <Watercolor position="top-right" opacity={0.30} variant={1} />

    <div class="site-container relative z-10">
      <ScrollReveal>
        <p class="font-script text-saffron text-center mb-3" style="font-size:20px; letter-spacing:0.04em;">
          Asked often
        </p>
        <h2 class="font-display font-medium text-forest text-center mb-14"
          style="font-size:clamp(2rem,4vw,3rem); line-height:1.1; max-width:32ch; margin-inline:auto;">
          Some things Likhitha gets asked.
        </h2>
      </ScrollReveal>

      <div class="faq-list max-w-[56ch] mx-auto">
        {faqs.map((item, i) => (
          <div class="faq-item" data-open={i === 0 ? 'true' : 'false'}>
            <button
              class="faq-trigger"
              aria-expanded={i === 0 ? 'true' : 'false'}
              aria-controls={`faq-answer-${i}`}
              id={`faq-btn-${i}`}
            >
              <span class="font-display italic text-forest" style="font-size:1.375rem; line-height:1.35;">{item.q}</span>
              <svg
                class="faq-chevron"
                width="20" height="20" viewBox="0 0 24 24"
                fill="none" stroke="#C99A4B" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <div
              class="faq-answer"
              id={`faq-answer-${i}`}
              role="region"
              aria-labelledby={`faq-btn-${i}`}
              hidden={i !== 0}
            >
              <p class="font-body text-ink/80" style="font-size:1.0625rem; line-height:1.7; padding:1rem 0 1.25rem;">
                {item.a}
              </p>
            </div>
            <div class="faq-rule" aria-hidden="true"></div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
       SECTION 5 — CLOSING BAND
  ══════════════════════════════════════════════════ -->
  <section class="relative bg-forest overflow-hidden" style="padding-top:8rem; padding-bottom:8rem;">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" aria-hidden="true">
      <DevanagariMark size={600} opacity={0.10} color="#C99A4B" />
    </div>

    <div class="relative z-10 site-container text-center">
      <ScrollReveal>
        <p class="font-script text-gold mb-5" style="font-size:22px; letter-spacing:0.03em;">— a brand promise</p>
        <h2 class="font-display italic font-medium text-cream mb-6"
          style="font-size:clamp(2.8rem,7vw,4.5rem); line-height:1.1; max-width:24ch; margin-inline:auto;">
          Ask and you shall receive.
        </h2>
        <p class="font-body leading-relaxed mb-12 mx-auto"
          style="font-size:17px; color:rgba(251,248,241,0.80); max-width:40ch;">
          It's a brand promise. Test it.
        </p>
        <a
          href="#contact-form"
          class="font-body font-medium text-forest bg-gold hover:bg-gold-dark transition-colors duration-200 inline-block mb-6"
          style="padding:16px 36px; font-size:15px; border-radius:9999px;"
        >
          Write to Likhitha
        </a>
        <div class="flex justify-center">
          <Ornament name="lotus" size={48} color="#C99A4B" class="opacity-60" />
        </div>
      </ScrollReveal>
    </div>
  </section>

</Base>


<style>
  /* ─── Hero word reveal ───────────────────────── */
  .chw {
    display: inline-block;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  /* ─── Form elements (same as /monday) ────────── */
  .contact-label {
    font-family: Inter, system-ui, sans-serif;
    font-size: 14px;
    letter-spacing: 0.06em;
    font-variant: small-caps;
    color: rgba(31,42,36,0.85);
  }
  .contact-input {
    background: #FBF8F1;
    border: 1px solid #C5D3C0;
    border-radius: 8px;
    padding: 16px 18px;
    font-family: Inter, system-ui, sans-serif;
    font-size: 17px;
    color: #1F2A24;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }
  .contact-input::placeholder {
    color: rgba(92,107,98,0.55);
  }
  .contact-input:focus {
    outline: none;
    border-color: #C99A4B;
    box-shadow: 0 0 0 3px rgba(201,154,75,0.20);
  }

  /* ─── Interest chips (Caveat style, like /testimonials) ── */
  .interest-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #C99A4B;
    transition: width 0.25s ease;
    border-radius: 1px;
  }
  .interest-btn:hover { color: #2C5F3F !important; }
  .interest-btn:hover::after { width: 100%; opacity: 0.5; }
  .interest-btn[aria-pressed="true"] { color: #2C5F3F !important; }
  .interest-btn[aria-pressed="true"]::after { width: 100%; }

  /* ─── Direct contact method cards ──────────────── */
  .contact-method-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #FBF8F1;
    border: 1px solid #C99A4B;
    border-radius: 12px;
    padding: 2.5rem;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-width 0.2s ease;
  }
  .contact-method-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px -12px rgba(31,42,36,0.14);
    border-width: 2px;
  }
  .contact-method-icon {
    margin-bottom: 1.25rem;
    transition: transform 0.45s ease;
  }

  /* ─── FAQ ─────────────────────────────────────── */
  .faq-list {
    display: flex;
    flex-direction: column;
  }
  .faq-rule {
    height: 1px;
    background: rgba(201,154,75,0.30);
    margin: 0;
  }
  .faq-item:last-child .faq-rule { display: none; }
  .faq-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }
  .faq-chevron {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }
  .faq-item[data-open="true"] .faq-chevron {
    transform: rotate(180deg);
  }
</style>


<script>
  // ── Hero word reveal ──
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll<HTMLElement>('.chw').forEach((el, i) => {
    if (reduced) { el.style.opacity = '1'; el.style.transform = 'none'; return; }
    el.style.transition = `opacity 0.55s ease ${100 + i * 80}ms, transform 0.55s ease ${100 + i * 80}ms`;
    requestAnimationFrame(() => requestAnimationFrame(() => {
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }));
  });

  // ── Interest chips multi-select ──
  const interestBtns = document.querySelectorAll<HTMLButtonElement>('.interest-btn');
  const hiddenContainer = document.getElementById('interest-hidden')!;
  const selected = new Set<string>();

  interestBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const val = btn.dataset.value!;
      if (selected.has(val)) {
        selected.delete(val);
        btn.setAttribute('aria-pressed', 'false');
      } else {
        selected.add(val);
        btn.setAttribute('aria-pressed', 'true');
      }
      // Sync hidden inputs
      hiddenContainer.innerHTML = '';
      selected.forEach(v => {
        const inp = document.createElement('input');
        inp.type = 'hidden';
        inp.name = 'interest';
        inp.value = v;
        hiddenContainer.appendChild(inp);
      });
    });
  });

  // ── FAQ accordion ──
  const faqItems = document.querySelectorAll<HTMLElement>('.faq-item');
  faqItems.forEach(item => {
    const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
    const answer  = item.querySelector<HTMLElement>('.faq-answer')!;
    trigger.addEventListener('click', () => {
      const isOpen = item.dataset.open === 'true';
      // Close all
      faqItems.forEach(fi => {
        fi.dataset.open = 'false';
        fi.querySelector<HTMLButtonElement>('.faq-trigger')!.setAttribute('aria-expanded', 'false');
        const ans = fi.querySelector<HTMLElement>('.faq-answer')!;
        ans.hidden = true;
      });
      // Open clicked if it was closed
      if (!isOpen) {
        item.dataset.open = 'true';
        trigger.setAttribute('aria-expanded', 'true');
        answer.hidden = false;
      }
    });
  });
</script>
