---
import Base from '../layouts/Base.astro';
import SectionEyebrow from '../components/SectionEyebrow.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site';

const offeringOptions = [
  { value: 'yoga',         label: 'Yoga' },
  { value: 'hands-on',     label: 'Hands-on Therapy' },
  { value: 'talk',         label: 'Talk Energy Clearance' },
  { value: 'consultation', label: 'Consultation' },
  { value: 'monday',       label: 'Monday Night Call' },
  { value: 'not-sure',     label: 'Not sure yet' },
];
---

<Base
  title="Contact & Book"
  description="Reach out to Likhitha Sree — no wrong door. Responses within 48 hours, personally."
>
  <!-- Header -->
  <section class="relative min-h-[50vh] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/portraits/02_park_full_body_embroidered_shirt.jpeg"
        alt="Likhitha Sree"
        class="w-full h-full object-cover object-top"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, transparent 20%, rgba(251,248,241,0.97) 100%);"
        aria-hidden="true"
      ></div>
    </div>
    <div class="relative site-container pb-16 w-full">
      <SectionEyebrow text="Get in touch" class="mb-3" />
      <h1 class="font-display text-4xl md:text-5xl text-forest">
        Ask. That's the practice.
      </h1>
      <p class="font-body text-lg text-muted mt-3 max-w-[48ch]">
        Whatever you're carrying, send it. There's no wrong door.
      </p>
    </div>
  </section>

  <!-- Form + direct channels -->
  <section class="bg-cream section-pad">
    <div class="site-container grid grid-cols-1 md:grid-cols-2 gap-16 items-start">

      <!-- Form -->
      <div>
        <form
          name="contact"
          method="POST"
          action="/success"
          class="flex flex-col gap-6"
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Don't fill this: <input name="bot-field" /></label>
          </p>

          <div class="flex flex-col gap-2">
            <label for="name" class="font-body text-sm font-medium text-ink">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              autocomplete="name"
              class="bg-cream border border-sage rounded px-4 py-3 text-base text-ink placeholder:text-muted/60 focus:outline-none focus:ring-2 focus:ring-gold/30 focus:border-gold transition"
              placeholder="Your name"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="reach" class="font-body text-sm font-medium text-ink">
              Best way to reach you
            </label>
            <input
              id="reach"
              name="reach"
              type="text"
              required
              class="bg-cream border border-sage rounded px-4 py-3 text-base text-ink placeholder:text-muted/60 focus:outline-none focus:ring-2 focus:ring-gold/30 focus:border-gold transition"
              placeholder="WhatsApp number or email"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="message" class="font-body text-sm font-medium text-ink">
              What's on your mind?
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              class="bg-cream border border-sage rounded px-4 py-3 text-base text-ink placeholder:text-muted/60 focus:outline-none focus:ring-2 focus:ring-gold/30 focus:border-gold transition resize-y"
              placeholder="Share as little or as much as you'd like."
            ></textarea>
          </div>

          <!-- Multi-select interest chips -->
          <fieldset>
            <legend class="font-body text-sm font-medium text-ink mb-3">
              What are you drawn to?
            </legend>
            <div class="flex flex-wrap gap-2">
              {offeringOptions.map(opt => (
                <label class="interest-chip cursor-pointer">
                  <input
                    type="checkbox"
                    name="interest"
                    value={opt.value}
                    class="sr-only peer"
                  />
                  <span class="font-body text-sm px-4 py-2 rounded-pill border border-forest/40 text-forest peer-checked:bg-forest peer-checked:text-cream peer-checked:border-forest transition-all duration-150 select-none">
                    {opt.label}
                  </span>
                </label>
              ))}
            </div>
          </fieldset>

          <Button type="submit" variant="primary" class="self-start mt-2">
            Send
          </Button>

          <p class="font-body text-xs text-muted">
            Sree responds personally — there's no funnel. Expect a reply within 48 hours.
          </p>
        </form>
      </div>

      <!-- Direct channels -->
      <div class="flex flex-col gap-8">
        <div>
          <p class="font-body text-xs uppercase tracking-[0.06em] text-gold font-medium mb-4">
            Or reach out directly
          </p>
          <div class="flex flex-col gap-5">
            <a
              href={site.socials.whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 group"
              aria-label="WhatsApp"
            >
              <div class="w-11 h-11 rounded-full bg-forest/10 flex items-center justify-center flex-shrink-0 group-hover:bg-gold/20 transition-colors">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#2C5F3F" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <p class="font-body text-sm font-medium text-forest">WhatsApp</p>
                <p class="font-body text-xs text-muted">{site.socials.whatsapp.replace('https://wa.me/', '+')}</p>
              </div>
            </a>

            <a
              href={site.socials.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 group"
              aria-label="Instagram"
            >
              <div class="w-11 h-11 rounded-full bg-forest/10 flex items-center justify-center flex-shrink-0 group-hover:bg-gold/20 transition-colors">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#2C5F3F" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </div>
              <div>
                <p class="font-body text-sm font-medium text-forest">Instagram</p>
                <p class="font-body text-xs text-muted">@sreespace</p>
              </div>
            </a>

            <a
              href={`mailto:${site.socials.email}`}
              class="flex items-center gap-4 group"
              aria-label="Email"
            >
              <div class="w-11 h-11 rounded-full bg-forest/10 flex items-center justify-center flex-shrink-0 group-hover:bg-gold/20 transition-colors">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2C5F3F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </div>
              <div>
                <p class="font-body text-sm font-medium text-forest">Email</p>
                <p class="font-body text-xs text-muted">{site.socials.email}</p>
              </div>
            </a>
          </div>
        </div>

        <div class="bg-sage/30 rounded-lg p-6">
          <p class="font-display italic text-xl text-forest leading-relaxed">
            "Come home to yourself."
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
