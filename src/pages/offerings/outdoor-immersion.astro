---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionEyebrow from '../../components/SectionEyebrow.astro';
import MondayCTA from '../../components/MondayCTA.astro';
import Button from '../../components/Button.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import Ornament from '../../components/Ornament.astro';
import { offerings } from '../../data/offerings';

const offering = offerings.find(o => o.slug === 'outdoor-immersion')!;
---

<Base
  title="Outdoor Immersion Programs"
  description="Nature-based group yoga and breathwork immersions — rivers, forests, hillsides at sunrise. Practice where the setting does the teaching."
>
  <Hero
    headline={offering.hero.headline}
    sub={offering.hero.sub}
    image={offering.hero.image}
    imageAlt="Likhitha Sree in a crescent lunge in a tropical garden — outdoor practice"
    primaryCta={{ label: 'Enquire about an immersion', onclick: "window.openWhatsApp('Outdoor immersion programs')" }}
    secondaryCta={{ label: 'Join the Awareness Circle', href: '/monday' }}
  />

  <!-- What it is -->
  <section class="bg-cream section-pad">
    <div class="site-container max-w-[800px]">
      <ScrollReveal>
        <SectionEyebrow text="What it is" class="mb-4" />
        <h2 class="font-display text-forest mb-6" style="font-size:clamp(2rem,4vw,3rem); line-height:1.1; font-weight:500;">
          The setting is part of the practice.
        </h2>
        <p class="font-body text-ink/80 leading-relaxed mb-5" style="font-size:1.06rem; max-width:60ch;">
          Outdoor Immersion Programs are group experiences held in natural settings —
          riverbanks, forest clearings, hillsides at dawn. Yoga, breathwork, and
          awareness practices taken outside the studio, where the uneven ground,
          the light, and the ambient sound become part of what you're working with.
        </p>
        <p class="font-body text-ink/70 leading-relaxed" style="font-size:1rem; max-width:60ch;">
          These aren't retreats or tourist experiences. They're practice sessions —
          held outdoors because nature removes the performance of it. There's nowhere
          to look good when a river is nearby and your feet are on actual earth.
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- What the setting offers -->
  <section class="bg-sage-wash section-pad">
    <div class="site-container max-w-[800px]">
      <ScrollReveal>
        <SectionEyebrow text="What shifts outdoors" class="mb-8" />
        <ul class="flex flex-col gap-6">
          {[
            { label: 'Breath lands differently', body: 'Open air, ambient sound, actual wind — pranayama and breathwork find a depth indoors rarely reaches.' },
            { label: 'The body stops performing', body: "Uneven terrain, natural light, no mirrors. You're in it rather than watching yourself be in it." },
            { label: 'Attention sharpens', body: 'Nature is the original object of meditation. The practice of noticing transfers immediately to the setting around you.' },
            { label: 'Group energy settles', body: 'Something quieter happens when a group practices together outside. The usual social static drops away faster.' },
          ].map(item => (
            <li class="flex items-start gap-5">
              <Ornament name="lotus" size={24} color="#C99A4B" class="flex-shrink-0 mt-1 opacity-75" />
              <div>
                <p class="font-display text-forest font-medium mb-1" style="font-size:1.15rem;">{item.label}</p>
                <p class="font-body text-ink/75 leading-relaxed" style="font-size:1rem;">{item.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </ScrollReveal>
    </div>
  </section>

  <!-- Practical info -->
  <section class="bg-cream section-pad">
    <div class="site-container max-w-[800px]">
      <ScrollReveal>
        <SectionEyebrow text="Practical" class="mb-6" />
        <ul class="flex flex-col gap-3">
          {[
            'Group sessions — small groups preferred, usually 4–12 people.',
            'Locations vary: rivers, forest edges, open hillsides. Ask about current venues.',
            'No prior yoga experience needed — the outdoors meets every level.',
            'Bring comfortable clothing, a mat or ground cloth, and water.',
            'Write to Likhitha to ask about upcoming dates and locations.',
          ].map(item => (
            <li class="flex items-start gap-3 font-body text-ink/80" style="font-size:1rem; line-height:1.65;">
              <span class="text-gold mt-1 flex-shrink-0" aria-hidden="true">—</span>
              {item}
            </li>
          ))}
        </ul>
      </ScrollReveal>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-cream section-pad border-t border-rule">
    <div class="site-container text-center">
      <ScrollReveal>
        <h2 class="font-display text-forest mb-4" style="font-size:clamp(1.8rem,3.5vw,2.5rem); font-weight:500;">
          Curious about the next session?
        </h2>
        <p class="font-body text-ink/70 mb-8 mx-auto" style="font-size:1rem; max-width:44ch; line-height:1.65;">
          Write to Likhitha with where you are and what you're drawn to — she'll let you know what's coming up.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <Button onclick="window.openWhatsApp('Outdoor immersion programs')" variant="primary">Enquire about an immersion</Button>
          <Button href="/monday" variant="secondary">Join the Awareness Circle</Button>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <MondayCTA />
</Base>
